services:
  {{ monitoring.adguard_home_exporter }}:
    image: ghcr.io/henrywhitaker3/adguard-exporter:v1.2.1
    restart: unless-stopped
    user: "{{ docker_compose_uid }}:{{ docker_compose_gid }}"
    environment:
      ADGUARD_SERVERS: "http://adguardhome"
      ADGUARD_USERNAMES: ${ADGUARD_USERNAME}
      ADGUARD_PASSWORDS: ${ADGUARD_PASSWORD}
      INTERVAL: "{{ monitoring.scraping_interval }}"
    networks:
      - {{ docker_networks.monitoring }}

networks:
  {{ docker_networks.monitoring }}:
    external: true
