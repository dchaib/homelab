DOMAIN=https://{{ homelab_services.vaultwarden.domain }}
INVITATIONS_ALLOWED=false
SHOW_PASSWORD_HINT=false
SIGNUPS_ALLOWED=false
SSO_ENABLED=true
SSO_ONLY=true
SSO_AUTHORITY=https://{{ homelab_services.authelia.domain }}
SSO_SCOPES=profile email offline_access vaultwarden
SSO_PKCE=true
SSO_CLIENT_ID={{ auth_oidc_clients.vaultwarden.client_id }}
SSO_CLIENT_SECRET={{ auth_oidc_clients.vaultwarden.client_secret }}
SSO_ROLES_ENABLED=true
SSO_ROLES_DEFAULT_TO_USER=true
SSO_ROLES_TOKEN_PATH=/vaultwarden_roles
