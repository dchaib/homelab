services:
  ntfy:
    image: binwiederhier/ntfy:v2.22.0
    restart: unless-stopped
    user: "{{ docker_compose_uid }}:{{ docker_compose_gid }}"
    command:
      - serve
    volumes:
      - {{ ntfy_docker_volumes.cache }}:/var/cache/ntfy
      - {{ ntfy_docker_volumes.users }}:/var/lib/ntfy
      - {{ ntfy_config_folder }}:/etc/ntfy
    networks:
      - {{ docker_networks.monitoring }}
      - {{ docker_networks.traefik }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.ntfy.rule=Host(`{{ homelab_services.ntfy.domain }}`)"
      - "traefik.http.routers.ntfy.entrypoints=websecure"
      - "traefik.http.routers.ntfy.tls=true"
      - "traefik.http.routers.ntfy.tls.certresolver=ovh"
      - "traefik.http.services.ntfy.loadbalancer.server.port=80"
      - "traefik.docker.network={{ docker_networks.traefik }}"

networks:
  {{ docker_networks.monitoring }}:
    external: true
  {{ docker_networks.traefik }}:
    external: true
