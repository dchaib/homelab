services:
  {{ monitoring.prometheus}}:
    image: prom/prometheus:v3.11.3-distroless
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--web.enable-remote-write-receiver'
    ports:
      - "9090:9090"
    volumes:
      - "{{ prometheus_config_folder }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "{{ prometheus_docker_volumes.data }}:/prometheus"
    networks:
      - {{ docker_networks.monitoring }}

networks:
  {{ docker_networks.monitoring }}:
    external: true
