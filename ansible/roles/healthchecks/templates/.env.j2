ALLOWED_HOSTS={{ homelab_services.healthchecks.domain }},healthchecks
DB=sqlite
DB_NAME=/data/hc.sqlite
DEFAULT_FROM_EMAIL={{ healthchecks.smtp.sender }}
INTEGRATIONS_ALLOW_PRIVATE_IPS=True
DEBUG=False
EMAIL_HOST={{ healthchecks.smtp.host }}
EMAIL_HOST_PASSWORD={{ healthchecks.smtp.password }}
EMAIL_HOST_USER={{ healthchecks.smtp.username }}
EMAIL_PORT={{ healthchecks.smtp.port }}
PROMETHEUS_ENABLED=True
REGISTRATION_OPEN=False
REMOTE_USER_HEADER=HTTP_REMOTE_EMAIL
SECRET_KEY={{ healthchecks.secret_key }}
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SITE_ROOT=https://{{ homelab_services.healthchecks.domain }}
